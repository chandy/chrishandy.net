---
import { SOCIALS } from "@/constants";
import LinkButton from "./LinkButton.astro";

export interface Props {
  centered?: boolean;
}

const { centered = false } = Astro.props;
---

<div class:list={["socials-container flex-wrap justify-center gap-2", { flex: centered }]}>
  {
    SOCIALS.map(social => (
      <LinkButton
        href={social.href}
        class="p-1.5 text-muted-foreground hover:text-foreground"
        title={social.linkTitle}
      >
        <social.icon class="inline-block size-4 fill-transparent stroke-current stroke-[1.5] opacity-80 group-hover:opacity-100" />
        <span class="sr-only">{social.linkTitle}</span>
      </LinkButton>
    ))
  }
</div>

<script is:inline>
  document.querySelectorAll('.socials-container a').forEach(function(link) {
    link.addEventListener('click', function() {
      window.posthog?.capture('social_link_clicked', {
        platform: link.getAttribute('title'),
        href: link.getAttribute('href'),
      });
    });
  });
</script>
