---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import LinkButton from "./LinkButton.astro";

export interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
---

{
  page.lastPage > 1 && (
    <nav class="mt-auto mb-12 flex items-center justify-center gap-4 text-sm text-muted-foreground" aria-label="Pagination">
      <LinkButton
        disabled={!page.url.prev}
        href={page.url.prev as string}
        class:list={["inline-flex items-center gap-1 select-none", { "opacity-40": !page.url.prev }]}
        ariaLabel="Previous"
      >
        <IconArrowLeft class="inline-block size-4 rtl:rotate-180" />
        Previous
      </LinkButton>
      <span>{page.currentPage} / {page.lastPage}</span>
      <LinkButton
        disabled={!page.url.next}
        href={page.url.next as string}
        class:list={["inline-flex items-center gap-1 select-none", { "opacity-40": !page.url.next }]}
        ariaLabel="Next"
      >
        Next
        <IconArrowRight class="inline-block size-4 rtl:rotate-180" />
      </LinkButton>
    </nav>
  )
}
