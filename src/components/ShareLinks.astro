---
import { SHARE_LINKS } from "@/constants";
import LinkButton from "./LinkButton.astro";

const URL = Astro.url;
---

{
  SHARE_LINKS.length > 0 && (
    <div class="flex flex-none flex-col items-start justify-center gap-3">
      <span class="text-xs font-medium tracking-wide text-muted-foreground uppercase">Share</span>
      <div class="flex gap-1">
        {SHARE_LINKS.map(social => (
          <LinkButton
            href={`${social.href + URL}`}
            class="p-1.5 text-muted-foreground hover:text-foreground"
            title={social.linkTitle}
          >
            <social.icon class="inline-block size-4 fill-transparent stroke-current stroke-[1.5] opacity-80 group-hover:opacity-100" />
            <span class="sr-only">{social.linkTitle}</span>
          </LinkButton>
        ))}
      </div>
    </div>
  )
}
