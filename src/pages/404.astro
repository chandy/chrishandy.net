---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    class="mx-auto flex max-w-app flex-1 items-center justify-center px-6"
  >
    <div class="mb-20 flex flex-col items-center justify-center text-center">
      <p class="text-sm font-medium tracking-wide text-muted-foreground uppercase">404</p>
      <h1 class="mt-4 text-3xl font-medium tracking-tight sm:text-4xl">Page not found</h1>
      <p class="mt-3 text-muted-foreground">The page you're looking for doesn't exist.</p>
      <LinkButton
        href="/"
        class="mt-8 text-sm text-muted-foreground hover:text-foreground"
      >
        Go back home
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>
